{
  "name": "@agent-notifier/crypto",
  "version": "0.1.0",
  "type": "module",
  "description": "WebCrypto wrappers for Agent Notifier E2EE.",
  "license": "MIT",
  "author": "Agent Notifier maintainers",
  "keywords": [
    "agent-notifier",
    "notifications",
    "crypto",
    "e2ee"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quick007/agent-notifier.git",
    "directory": "packages/crypto"
  },
  "homepage": "https://github.com/quick007/agent-notifier",
  "bugs": {
    "url": "https://github.com/quick007/agent-notifier/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "vp exec tsc -p tsconfig.build.json",
    "pack:dry-run": "vp run build && npm pack --dry-run --json",
    "test": "vp run build && node --test test/*.test.ts",
    "typecheck": "vp exec tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "vite-plus": "catalog:"
  }
}
