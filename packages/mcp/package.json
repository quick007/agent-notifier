{
  "name": "@agent-notifier/mcp",
  "version": "0.1.0",
  "description": "Local stdio MCP server for Agent Notifier.",
  "license": "MIT",
  "author": "Agent Notifier maintainers",
  "keywords": [
    "agent-notifier",
    "notifications",
    "mcp",
    "agents"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quick007/agent-notifier.git",
    "directory": "packages/mcp"
  },
  "homepage": "https://github.com/quick007/agent-notifier#readme",
  "bugs": {
    "url": "https://github.com/quick007/agent-notifier/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "agent-notifier-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && pnpm exec vitest run --passWithNoTests",
    "pack:dry-run": "npm pack --dry-run --json"
  },
  "dependencies": {
    "@agent-notifier/cli": "workspace:*"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
