{
  "name": "agent-notifier",
  "version": "0.1.0",
  "private": true,
  "description": "Encrypted notifications and lightweight approvals for AI agents.",
  "license": "MIT",
  "author": "Agent Notifier maintainers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quick007/agent-notifier.git"
  },
  "bugs": {
    "url": "https://github.com/quick007/agent-notifier/issues"
  },
  "homepage": "https://github.com/quick007/agent-notifier",
  "keywords": [
    "agent",
    "notifications",
    "approvals",
    "e2ee",
    "mcp",
    "cloudflare-workers"
  ],
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "vp run @agent-notifier/web#dev",
    "build": "vp run --filter @agent-notifier/* build",
    "typecheck": "vp run --filter @agent-notifier/* typecheck",
    "test": "vp run --filter @agent-notifier/* test",
    "check:file-length": "vp exec tsx scripts/check-file-length.ts",
    "check:packages": "node scripts/verify-packages.mjs",
    "check": "vp run -w typecheck && vp run -w test && vp run -w check:file-length && vp run -w check:packages",
    "deploy:web:dry-run": "vp run @agent-notifier/web#deploy:dry-run",
    "deploy:web": "vp run @agent-notifier/web#deploy"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "wrangler": "4.106.0"
  }
}
